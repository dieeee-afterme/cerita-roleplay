name: Pengumuman Update Warga

on:
  push:
    branches:
      - main # (Ganti master kalau branch lu master)

jobs:
  kirim-pengumuman:
    runs-on: ubuntu-latest
    steps:
      - name: Ambil Data Commit Lu
        id: commit_data
        run: echo "MSG=$(jq -r '.head_commit.message' "$GITHUB_EVENT_PATH")" >> $GITHUB_ENV

      - name: Kirim Format Keren ke Discord Warga
        env:
          WEBHOOK_URL: ${{ secrets.WEBHOOK_WARGA }}
        run: |
          curl -H "Content-Type: application/json" -X POST -d "$(jq -n \
            --arg msg "$MSG" \
            '{content: "<@&1466700911890923786>\n\n# ║ UPDATE PATCH KOTA ║\nYo warga, ada update terbaru nih dari pusat yang udah masuk kota. Check this out!\n\n**Changelog:**\n
http://googleusercontent.com/immersive_entry_chip/0

Nanti GitHub bakal otomatis ngerjain file `.yml` itu di *background*, dan *boom*! Pengumumannya bakal langsung meluncur ke Discord warga lu pake format yang rapi banget, lengkap dengan ping *role* dan warna `diff`-nya. Gass cobain bre!
